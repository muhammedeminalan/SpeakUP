  "cümleler": [
    {
      "id": 1,
      "türkçe": "Ben her sabah kahve içerim.",
      "devrik": "Ben içerim kahve her sabah.",
      "ingilizce": "I drink coffee every morning."
    },
    {
      "id": 2,
      "türkçe": "Ben hafta sonları uyurum.",
      "devrik": "Ben uyurum hafta sonları.",
      "ingilizce": "I always sleep on weekends."
    },
    {
      "id": 3,
      "türkçe": "Ben akşamları yürüyüş yaparım.",
      "devrik": "Ben yaparım yürüyüş akşamları.",
      "ingilizce": "I go for a walk in the evenings."
    },
    {
      "id": 4,
      "türkçe": "Ben ablamla gıybet ederim.",
      "devrik": "Ben gıybet ederim ablamla.",
      "ingilizce": "I gossip with my sister."
    },
    {
      "id": 5,
      "türkçe": "Ben menemen pişirmeyi bilirim.",
      "devrik": "Ben bilirim menemen pişirmeyi.",
      "ingilizce": "I know how to cook menemen."
    },
    {
      "id": 6,
      "türkçe": "Ben işten sonra müzik dinlerim.",
      "devrik": "Ben dinlerim müzik işten sonra.",
      "ingilizce": "I listen to music after work."
    },
    {
      "id": 7,
      "türkçe": "Ben yaz tatillerinde denize girerim.",
      "devrik": "Ben girerim denize yaz tatillerinde.",
      "ingilizce": "I swim in the sea during summer vacations."
    },
    {
      "id": 8,
      "türkçe": "Ben hafta içi spor salonuna giderim.",
      "devrik": "Ben giderim spor salonuna hafta içi.",
      "ingilizce": "I go to the gym on weekdays."
    },
    {
      "id": 9,
      "türkçe": "Ben marketten taze sebze alırım.",
      "devrik": "Ben alırım taze sebze marketten.",
      "ingilizce": "I buy fresh vegetables from the market."
    },
    {
      "id": 10,
      "türkçe": "Ben her gün kilomu kontrol ederim.",
      "devrik": "Ben kontrol ederim kilomu her gün.",
      "ingilizce": "I check my weight every day."
    },
    {
      "id": 11,
      "türkçe": "Sen çok hızlı yürürsün.",
      "devrik": "Sen yürürsün çok hızlı.",
      "ingilizce": "You walk very fast."
    },
    {
      "id": 12,
      "türkçe": "Sen onu pazarda görürsün.",
      "devrik": "Sen görürsün onu pazarda.",
      "ingilizce": "You see him at the bazaar."
    },
    {
      "id": 13,
      "türkçe": "Sen otobüsle okula gidersin.",
      "devrik": "Sen gidersin okula otobüsle.",
      "ingilizce": "You go to school by bus."
    },
    {
      "id": 14,
      "türkçe": "Sen arkadaşlarına mesaj atarsın.",
      "devrik": "Sen atarsın mesaj arkadaşlarına.",
      "ingilizce": "You send messages to your friends."
    },
    {
      "id": 15,
      "türkçe": "Sen hafta sonları dışarıda yemek yersin.",
      "devrik": "Sen yersin yemek dışarıda hafta sonları.",
      "ingilizce": "You eat out on weekends."
    },
    {
      "id": 16,
      "türkçe": "Sen müzik dinlerken ders çalışırsın.",
      "devrik": "Sen çalışırsın ders müzik dinlerken.",
      "ingilizce": "You study while listening to music."
    },
    {
      "id": 17,
      "türkçe": "Sen telefonunu yanında taşırsın.",
      "devrik": "Sen taşırsın telefonunu yanında.",
      "ingilizce": "You carry your phone with you."
    },
    {
      "id": 18,
      "türkçe": "Sen sabahları duş alırsın.",
      "devrik": "Sen alırsın duş sabahları.",
      "ingilizce": "You take a shower in the mornings."
    },
    {
      "id": 19,
      "türkçe": "Sen bana yardım edersin.",
      "devrik": "Sen yardım edersin bana.",
      "ingilizce": "You always help me."
    },
    {
      "id": 20,
      "türkçe": "Sen yazları tatil köylerine gidersin.",
      "devrik": "Sen gidersin tatil köylerine yazları.",
      "ingilizce": "You go to resorts in the summer."
    },
    {
      "id": 21,
      "türkçe": "Siz düğüne gelirsiniz.",
      "devrik": "Siz gelirsiniz düğüne.",
      "ingilizce": "You come to the wedding."
    },
    {
