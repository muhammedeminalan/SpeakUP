    { "id": 11, "türkçe": "Onlar toplantıya katılmıyor.", "devrik": "Onlar katılmıyor toplantıya.", "ingilizce": "They don't attend the meeting." },
    { "id": 12, "türkçe": "Ben bunu planlamıyorum.", "devrik": "Ben planlamıyorum bunu.", "ingilizce": "I don't plan this." },
    { "id": 13, "türkçe": "Siz etkinliği organize etmiyorsunuz.", "devrik": "Siz organize etmiyorsunuz etkinliği.", "ingilizce": "You don't organize the event." },
    { "id": 14, "türkçe": "Onlar rapor yazmıyor.", "devrik": "Onlar yazmıyor rapor.", "ingilizce": "They don't write reports." },
