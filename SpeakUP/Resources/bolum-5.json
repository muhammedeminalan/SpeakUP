  "cümleler": [
    { "id": 1, "türkçe": "Ben seni anlamıyorum.", "devrik": "Ben anlamıyorum seni.", "ingilizce": "I don't understand you." },
    { "id": 2, "türkçe": "Sen konuyu açıklamıyorsun.", "devrik": "Sen açıklamıyorsun konuyu.", "ingilizce": "You don't explain the topic." },
    { "id": 3, "türkçe": "Biz soru sormuyoruz.", "devrik": "Biz sormuyoruz soru.", "ingilizce": "We don't ask questions." },
    { "id": 4, "türkçe": "Onlar cevap vermiyor.", "devrik": "Onlar vermiyor cevap.", "ingilizce": "They don't answer." },
    { "id": 5, "türkçe": "Siz bizimle konuşmuyorsunuz.", "devrik": "Siz konuşmuyorsunuz bizimle.", "ingilizce": "You don't speak with us." },
    { "id": 6, "türkçe": "Ben bunu söylemiyorum.", "devrik": "Ben söylemiyorum bunu.", "ingilizce": "I don't say this." },
    { "id": 7, "türkçe": "Sen ona bir şey demiyorsun.", "devrik": "Sen demiyorsun ona bir şey.", "ingilizce": "You don't tell him anything." },
    { "id": 8, "türkçe": "Biz dikkatlice dinlemiyoruz.", "devrik": "Biz dinlemiyoruz dikkatlice.", "ingilizce": "We don't listen carefully." },
    { "id": 9, "türkçe": "Onlar hiçbir şey duymuyor.", "devrik": "Onlar duymuyor hiçbir şey.", "ingilizce": "They don't hear anything." },
